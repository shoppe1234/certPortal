# certPortal Environment Variables — Dev/Staging
# Copy to .env and fill in values. NEVER commit .env.

# OVHcloud Object Storage (S3-compatible)
OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
OVH_S3_KEY=
OVH_S3_SECRET=
OVH_S3_REGION=gra
OVH_S3_WORKSPACE_BUCKET=certportal-workspaces
OVH_S3_RAW_EDI_BUCKET=certportal-raw-edi

# OVHcloud Managed PostgreSQL
CERTPORTAL_DB_URL=postgresql://user:pass@host:5432/certportal

# OpenAI
OPENAI_API_KEY=sk-...

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
CERTPORTAL_JWT_SECRET=

# Slack webhooks (optional — agents fail gracefully if absent)
SLACK_CERTPORTAL_UI_WEBHOOK=
SLACK_CERTPORTAL_OPS_WEBHOOK=

# Kelly SMTP dispatch — email channel (ADR-020)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=certportal@example.com

# Kelly Google Chat OAuth tokens — per retailer (ADR-020)
# KELLY_GOOGLE_CHAT_OAUTH_TOKEN_ELIOR=
# KELLY_GOOGLE_CHAT_OAUTH_TOKEN_LOWES=

# Kelly Teams incoming webhook URLs — per retailer (ADR-020)
# (Teams uses webhook URLs, not OAuth tokens — note: old KELLY_TEAMS_OAUTH_TOKEN_* keys are deprecated)
# KELLY_TEAMS_WEBHOOK_ELIOR=
# KELLY_TEAMS_WEBHOOK_LOWES=

# Kelly thread memory consolidation — Gemini Flash-Lite (ADR-024)
# Leave blank in dev; Kelly gracefully skips consolidation when absent.
GEMINI_API_KEY=
