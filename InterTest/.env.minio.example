# .env.minio.example
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env when using MinIO for local development / integration tests.
#
# Start MinIO first:
#   docker compose -f docker-compose.minio.yml up -d
#
# Then set up buckets + fixtures (one-time):
#   python testing/integration/setup_minio.py
#
# To switch BACK to OVHcloud, restore your production OVH_S3_* values.
# No code changes are required — all portals and tests use settings.ovh_s3_*.
# ──────────────────────────────────────────────────────────────────────────────

# ── S3: MinIO (local dev) ─────────────────────────────────────────────────────
OVH_S3_ENDPOINT=http://localhost:9000
OVH_S3_KEY=minioadmin
OVH_S3_SECRET=minioadmin
OVH_S3_REGION=us-east-1
OVH_S3_WORKSPACE_BUCKET=certportal-workspaces
OVH_S3_RAW_EDI_BUCKET=certportal-raw-edi

# ── PostgreSQL (Docker container — unchanged from production config) ───────────
CERTPORTAL_DB_URL=postgresql://certportal:certportal@localhost:5432/certportal

# ── Portal JWT secret (use your real value) ───────────────────────────────────
# SECRET_KEY=your-secret-key-here

# ── OpenAI (required by agents — use real key or stub) ───────────────────────
# OPENAI_API_KEY=sk-...
